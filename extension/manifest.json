{
  "manifest_version": 3,
  "name": "PhishGuard",
  "version": "1.0",
  "description": "An ML-Powered Phishing URL Detection System",
  "permissions": ["activeTab", "storage", "webNavigation"],
  "host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background/background.js",
    "scripts": ["background/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "phishguard@rahul626-stack.com"
    }
  }
}
